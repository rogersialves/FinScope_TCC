# Flake8 configuration
# Note: flake8 does not natively support pyproject.toml
# This file mirrors the settings from pyproject.toml

[flake8]
max-line-length = 100
extend-ignore = E203, E501, W503
exclude =
    .git,
    __pycache__,
    site,
    build,
    dist,
    .venv,
    *.egg-info

# Per-file ignores
per-file-ignores =
    __init__.py: F401
    tests/*: S101

# McCabe complexity
max-complexity = 15
